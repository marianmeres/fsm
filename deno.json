{
	"name": "@marianmeres/fsm",
	"version": "2.16.5",
	"exports": {
		".": "./src/mod.ts",
		"./mermaid-to-typescript": "./scripts/mermaid-to-typescript.ts"
	},
	"tasks": {
		"test": "deno test",
		"test:watch": "deno test --watch",
		"npm:build": "deno run -A scripts/build-npm.ts",
		"npm:publish": "deno run -A scripts/build-npm.ts && cd ./.npm-dist && npm publish --access=public",
		"release": "deno run -A jsr:@marianmeres/deno-release",
		"publish": "deno publish && deno task npm:publish",
		"rp": "deno task release -y && deno task publish",
		"rpm": "deno task release minor -y && deno task publish"
	},
	"imports": {
		"@marianmeres/fsm": "./src/mod.ts",
		"@marianmeres/clog": "jsr:@marianmeres/clog@^3.17.0",
		"@marianmeres/npmbuild": "jsr:@marianmeres/npmbuild@^1.12.0",
		"@marianmeres/pubsub": "jsr:@marianmeres/pubsub@^3.0.0",
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"@std/cli": "jsr:@std/cli@^1.0.28",
		"@std/collections": "jsr:@std/collections@^1.1.6",
		"@std/fs": "jsr:@std/fs@^1.0.23",
		"@std/path": "jsr:@std/path@^1.1.4"
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 90,
		"indentWidth": 4
	}
}
